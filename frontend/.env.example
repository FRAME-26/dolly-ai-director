# Optional: FastAPI backend base URL. When unset, the frontend runs its honest
# demo mode (labeled mock cameras, browser SpeechRecognition, no fake backends).
#
# Local dev (backend on this machine, started with `uvicorn app.main:app`):
VITE_DOLLY_API=http://localhost:8000
#
# Production (the Linux server running backend/ via systemd):
# VITE_DOLLY_API=https://your-dolly-server.example.com
